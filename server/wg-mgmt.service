[Unit]
Description=WireGuard Management Daemon
After=network-online.target wg-quick@wg0.service
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/wg-mgmt-daemon --config=__CONFIG_PATH__
Restart=always
RestartSec=5

ProtectSystem=strict
ProtectHome=yes
NoNewPrivileges=yes
ReadWritePaths=__PROJECT_DIR__/server /etc/wireguard
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
