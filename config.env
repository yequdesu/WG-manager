# WireGuard Management Layer Configuration
# Generated by setup-server.sh

# WireGuard Interface
WG_INTERFACE=wg0
WG_PORT=51820

# VPN Subnet
WG_SUBNET=10.0.0.0/24
WG_SERVER_IP=10.0.0.1/24

# Server Public IP (required)
SERVER_PUBLIC_IP=

# Management API
MGMT_LISTEN=0.0.0.0:58880
MGMT_API_KEY=

# Default DNS for clients
DEFAULT_DNS=1.1.1.1,8.8.8.8

# Audit log
AUDIT_LOG_PATH=/var/log/wg-mgmt/audit.log

# Peer settings
PEER_KEEPALIVE=25

# File paths
PEERS_DB_PATH=./server/peers.json
WG_CONF_PATH=/etc/wireguard/wg0.conf
